# Docker Compose secrets/config template.
# Copy this file to .env and replace values before running `docker compose up`.

MARIADB_DATABASE=event_registrations
MARIADB_USER=appuser
MARIADB_PASSWORD=appsecret
MARIADB_ROOT_PASSWORD=rootsecret
MARIADB_SERVER_VERSION=11.4.0-mariadb
SHARED_ACCESS_PASSWORD=change-me

# Optional
ASPNETCORE_ENVIRONMENT=Production
